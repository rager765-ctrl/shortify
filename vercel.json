{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/:path*\\.:ext",
      "destination": "/:path*.:ext"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
